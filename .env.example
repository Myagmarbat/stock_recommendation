# OpenAI
OPENAI_API_KEY=
STOCK_RECOMMENDATION_AI=1
STOCK_RECOMMENDATION_MODEL=gpt-5-nano
STOCK_RECOMMENDATION_AI_MONTHLY_BUDGET_USD=3.00
STOCK_RECOMMENDATION_AI_MAX_OUTPUT_TOKENS=1200
STOCK_RECOMMENDATION_OPENAI_INPUT_PRICE_PER_MILLION=0.05
STOCK_RECOMMENDATION_OPENAI_OUTPUT_PRICE_PER_MILLION=0.40

# LangSmith tracing, optional
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=stock_recommendation
